# =============================================================================
# IDK Digital Solutions — .gitignore
# =============================================================================

# ── Terraform ─────────────────────────────────────────────────────────────────
# Local .terraform directories contain provider binaries (100MB+) and
# cached modules. Never commit these.
**/.terraform/
# NOTE: .terraform.lock.hcl is intentionally NOT ignored — it must be committed
# to ensure reproducible provider versions across all environments and CI/CD.

# Terraform state files — contain sensitive resource data
# State lives in S3 (remote backend), never in Git
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform plan files can contain sensitive data (passwords, keys)
*.tfplan
*.plan

# Terraform variable files with actual values (not examples)
# Use terraform.tfvars.example files instead
terraform.tfvars
terraform.tfvars.json
*.auto.tfvars
*.auto.tfvars.json

# Terraform crash logs
crash.log
crash.*.log

# Override files — used for local development overrides
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ── AWS Credentials ────────────────────────────────────────────────────────────
# NEVER commit AWS credentials. Ever.
.aws/
credentials
*_credentials.csv
*.pem
*.key
*.p12

# ── Secrets & Environment ─────────────────────────────────────────────────────
.env
.env.*
*.secret
secrets/
*secret*
*password*
*passwd*

# ── SSH Keys ──────────────────────────────────────────────────────────────────
id_rsa
id_ed25519
*.pub
# Exception: committed public keys are fine
!docs/**/*.pub

# ── OS & IDE ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

.vscode/settings.json
.idea/
*.swp
*.swo

# ── Python (used in scripts) ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.venv/
venv/
.python-version

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
